# Public Supabase client values used by the Vite app and Vercel.
# Copy this file to .env.local and replace both placeholders.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-or-anon-key>

# Optional server-only AI judge values for Vercel/api/judge.js.
# Do not prefix these with VITE_.
JUDGE_PROVIDER=local
OPENAI_API_KEY=<openai-api-key>
OPENAI_JUDGE_MODEL=gpt-4o-mini
VITE_HOSTED_TTS_ENABLED=false
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=onyx

# Optional hosted/free judge provider for Vercel.
# Use JUDGE_PROVIDER=groq with a server-only Groq key.
GROQ_API_KEY=<groq-api-key>
GROQ_JUDGE_MODEL=llama-3.1-8b-instant

# Optional local/free judge provider for development with D:\LocalAI.
# Use JUDGE_PROVIDER=ollama locally; do not deploy this provider to Vercel.
OLLAMA_JUDGE_URL=http://127.0.0.1:11434/api/chat
OLLAMA_JUDGE_MODEL=text-judge
