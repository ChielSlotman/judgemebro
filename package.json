{
  "name": "judgemebro",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:judge": "node scripts/judge-api-test.mjs",
    "test:tts": "node scripts/tts-api-test.mjs",
    "test:supabase": "node scripts/supabase-schema-check.mjs",
    "check:multiplayer-production": "node scripts/production-multiplayer-check.mjs",
    "test:workflows": "node scripts/workflow-check.mjs",
    "test:deployment": "node scripts/deployment-check.mjs",
    "test:domain": "node scripts/domain-check.mjs",
    "test:docs": "node scripts/docs-check.mjs",
    "test:env-example": "node scripts/env-example-check.mjs",
    "test:vercel-env-sync": "node scripts/sync-vercel-env.mjs --dry-run --env-file scripts/fixtures/supabase-client.env",
    "test:vercel-server-env-sync": "node scripts/sync-vercel-server-env.mjs --dry-run --env-file scripts/fixtures/server-ai.env",
    "test:smoke": "node scripts/smoke-test.mjs",
    "verify": "node scripts/verify.mjs",
    "check:providers": "node scripts/provider-readiness-check.mjs",
    "launch:audit": "node scripts/launch-audit.mjs",
    "domain:check": "node scripts/domain-check.mjs --inspect-vercel",
    "sync:vercel-env": "node scripts/sync-vercel-env.mjs",
    "sync:vercel-server-env": "node scripts/sync-vercel-server-env.mjs",
    "github:create": "node scripts/github-create-repo.mjs",
    "test:github-create": "node scripts/github-create-repo.mjs --dry-run --name judgemebro",
    "github:publish": "node scripts/github-publish.mjs",
    "test:github-publish": "node scripts/github-publish.mjs --dry-run --remote https://github.com/ChielSlotman/judgemebro.git --connect-vercel",
    "supabase:migrate": "node scripts/supabase-migrate.mjs",
    "test:supabase-migrate": "node scripts/supabase-migrate.mjs --plan-only --project-ref example-project-ref",
    "setup:check": "node scripts/setup-check.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "@vitejs/plugin-react": "5.0.4",
    "lucide-react": "0.468.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
